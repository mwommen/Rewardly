{
  "manifest_version": 3,
  "name": "Rewardly",
  "version": "1.0",
  "description": "Shows the credit card benefit or best card to use when you reach checkout.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:5001/*",
    "http://localhost/*",
    "https://amazon.com/*",
    "https://www.amazon.com/*",
    "https://smile.amazon.com/*",
    "https://www.lululemon.com/*",
    "https://shop.lululemon.com/*",
    "https://checkout.lululemon.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "https://amazon.com/*",
        "https://www.amazon.com/*",
        "https://smile.amazon.com/*",
        "https://www.lululemon.com/*",
        "https://shop.lululemon.com/*",
        "https://checkout.lululemon.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Rewardly"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/card-logos/*"],
      "matches": [
        "http://localhost/*",
        "https://amazon.com/*",
        "https://www.amazon.com/*",
        "https://smile.amazon.com/*",
        "https://www.lululemon.com/*",
        "https://shop.lululemon.com/*",
        "https://checkout.lululemon.com/*"
      ]
    }
  ]
}
