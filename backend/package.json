{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend for Credit Card Optimizer App",
  "main": "index.js",
  "license": "ISC",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "test": "jest --passWithNoTests",
    "seed": "ts-node ./seedCards.ts",
    "seed:demo": "ts-node ./demo/seedDemo.ts",
    "demo:reset": "ts-node ./demo/resetDemo.ts",
    "scrape:card": "ts-node ./src/scrapers/scrapeCard.ts",
    "scrape:weekly": "ts-node ./src/scrapers/weeklyRescrape.ts",
    "pipeline:weekly": "npm run scrape:weekly && npm run cleanup:benefits -- --apply && npm run validate:benefits && ts-node ./src/benefitsAudit.ts",
    "cleanup:benefits": "ts-node ./src/cleanupBenefits.ts",
    "cleanup:cards": "ts-node ./src/cleanupCards.ts",
    "validate:scrape": "ts-node ./src/validateScrape.ts",
    "validate:benefits": "ts-node ./src/validateBenefitsQuality.ts",
    "validate:benefits:accuracy": "ts-node ./src/validateBenefitsAccuracy.ts"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^24.9.1",
    "@types/node-fetch": "^2.6.13",
    "@types/js-yaml": "^4.0.9",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cheerio": "^1.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "js-yaml": "^4.1.0",
    "mongodb": "^6.20.0",
    "mongoose": "^8.18.0",
    "node-fetch": "^3.3.2",
    "plaid": "^39.0.0",
    "playwright": "^1.56.1"
  }
}
