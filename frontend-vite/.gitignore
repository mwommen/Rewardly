# --- Node / TypeScript ---
node_modules/
dist/
build/
*.tsbuildinfo
coverage/
.nyc_output/

# --- Logs & caches ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.cache/
.tmp/
.tmp-*
