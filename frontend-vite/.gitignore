.eslintcache

# --- Env & secrets (ROOT + subpackages) ---
.env
.env.*
!.env.example
!.env.*.example

# --- Playwright / Puppeteer ---
playwright-report/
test-results/
blob-report/
*.zip
*.webm
*.mp4
*.png
.playwright/
.playwright-*
