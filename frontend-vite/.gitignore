# --- Backend artifacts ---
backend/node_modules/
backend/dist/
backend/coverage/
backend/*.tsbuildinfo

# --- Misc ---
*.local
*.secret
*.pem
*.key
*.crt
*.p12

# --- Mac quarantine files ---
._*


# Frontend env (NO SECRETS)
