# --- Chrome Extension artifacts ---
frontend/dist/
frontend/build/
frontend/.vite/
frontend/.parcel-cache/
frontend/.next/
frontend/.turbo/

# --- Frontend tooling ---
frontend/node_modules/
frontend/coverage/
